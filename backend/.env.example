# ============================================
# ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================
# GROQ API (REQUIRED)
# ============================================
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ============================================
# DATABASE (REQUIRED FOR PRODUCTION)
# ============================================
# PostgreSQL connection details
POSTGRES_USER=resume_user
POSTGRES_PASSWORD=change_this_secure_password_in_production
POSTGRES_DB=resume_screening
DATABASE_URL=postgresql://resume_user:change_this_secure_password_in_production@localhost:5432/resume_screening

# ============================================
# REDIS (OPTIONAL - FOR RATE LIMITING)
# ============================================
REDIS_URL=redis://localhost:6379/0

# ============================================
# APPLICATION SETTINGS
# ============================================
# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode (set to false in production)
DEBUG=true

# Logging level: debug, info, warning, error, critical
LOG_LEVEL=info

# ============================================
# SECURITY
# ============================================
# API key for protected endpoints (optional)
# Leave empty to disable API key authentication
API_KEY=

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Secret key for session management (generate with: openssl rand -hex 32)
SECRET_KEY=change_this_to_a_random_secret_key_in_production

# ============================================
# RATE LIMITING
# ============================================
# Enable rate limiting
RATE_LIMIT_ENABLED=true

# Requests per minute per IP
RATE_LIMIT_PER_MINUTE=60

# ============================================
# FILE UPLOAD LIMITS
# ============================================
# Maximum file size in MB
MAX_FILE_SIZE_MB=10

# Maximum number of resumes in batch upload
MAX_BATCH_SIZE=20

# ============================================
# AI MODEL CONFIGURATION
# ============================================
# Model to use for resume/job parsing
PARSING_MODEL=llama-3.3-70b-versatile

# Model to use for matching and scoring
SCORING_MODEL=llama-3.3-70b-versatile

# Model to use for feedback generation
FEEDBACK_MODEL=llama-3.3-70b-versatile

# Temperature for AI responses (0.0 - 1.0)
AI_TEMPERATURE=0.1

# Maximum tokens for AI responses
MAX_TOKENS=8000

# ============================================
# SCREENING THRESHOLDS
# ============================================
# Score threshold for HIRE decision (0-100)
HIRE_THRESHOLD=75.0

# Score threshold for REJECT decision (0-100)
REJECT_THRESHOLD=50.0

# ============================================
# DOCKER SETTINGS
# ============================================
# Number of uvicorn workers (set to number of CPU cores)
WORKERS=4

# ============================================
# MONITORING (OPTIONAL)
# ============================================
# Sentry DSN for error tracking
SENTRY_DSN=

# ============================================
# EMAIL NOTIFICATIONS (OPTIONAL)
# ============================================
# SMTP settings for notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=azam.mdnajibul@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@resumescreening.com
